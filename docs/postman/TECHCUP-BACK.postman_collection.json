            "url": {
              "raw": "{{baseUrl}}/api/lineups/team/{{teamId}}/match/{{matchId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lineups", "team", "{{teamId}}", "match", "{{matchId}}"]
