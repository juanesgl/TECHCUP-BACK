  "item": [
    {
      "name": "Auth y Usuarios",
      "item": [
        {
          "name": "Registrar Usuario",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Isaac\",\n  \"email\": \"usuario@example.com\",\n  \"password\": \"Password123*\",\n  \"role\": \"PLAYER\",\n  \"preferredPosition\": \"MIDFIELDER\",\n  \"skillLevel\": 4\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "register"]
            },
            "description": "UserController"
          }
        },
        {
          "name": "Login Usuario",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuario@example.com\",\n  \"password\": \"Password123*\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "login"]
            },
            "description": "AuthController"
          }
        }
      ]
    },
    {
      "name": "Torneos",
      "item": [
        {
          "name": "Crear Torneo",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"TechCup 2026\",\n  \"startDate\": \"2026-04-01\",\n  \"endDate\": \"2026-06-30\",\n  \"maxTeams\": 16,\n  \"costPerTeam\": 120.0,\n  \"regulation\": \"Reglamento oficial TechCup\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tournaments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tournaments"]
            },
            "description": "TournamentController"
          }
        },
        {
          "name": "Listar Torneos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tournaments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tournaments"]
            },
            "description": "TournamentController"
          }
        },
        {
          "name": "Iniciar Torneo",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tournaments/{{tournamentId}}/start",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tournaments", "{{tournamentId}}", "start"]
            },
            "description": "TournamentController"
          }
        },
        {
          "name": "Finalizar Torneo",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/tournaments/{{tournamentId}}/finish",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tournaments", "{{tournamentId}}", "finish"]
            },
            "description": "TournamentController"
          }
        },
        {
          "name": "Configurar Torneo",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registrationCloseDate\": \"2026-03-25\",\n  \"canchas\": [\n    {\n      \"nombre\": \"Cancha Central\",\n      \"ubicacion\": \"Campus Norte\"\n    }\n  ],\n  \"importantDates\": \"Sorteo de grupos: 2026-03-28\",\n  \"matchSchedules\": \"Sabados de 8AM a 6PM\",\n  \"sanctions\": \"Roja directa = 1 partido\",\n  \"regulation\": \"Reglamento liga interna\",\n  \"organizerId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/torneos/{{tournId}}/configuracion",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "torneos", "{{tournId}}", "configuracion"]
            },
            "description": "ConfiguracionTorneoController"
          }
        },
        {
          "name": "Estadisticas de Torneo",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/estadisticas/torneo/{{tournId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "estadisticas", "torneo", "{{tournId}}"]
            },
            "description": "EstadisticasController"
          }
        },
        {
          "name": "Tabla de Posiciones",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tournaments/{{tournamentId}}/standings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tournaments", "{{tournamentId}}", "standings"]
            },
            "description": "StandingsTableController"
          }
        }
      ]
    },
    {
      "name": "Equipos, Invitaciones y Jugadores",
      "item": [
        {
          "name": "Crear Equipo",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Capitan-ID", "value": "{{capitanId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreEquipo\": \"Los Titanes\",\n  \"escudo\": \"https://example.com/escudo.png\",\n  \"coloresUniforme\": \"Azul y blanco\",\n  \"jugadoresInvitadosIds\": [2, 3, 4, 5, 6, 7]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/equipos/crear",
              "host": ["{{baseUrl}}"],
              "path": ["api", "equipos", "crear"]
            },
            "description": "EquipoController"
          }
        },
        {
          "name": "Actualizar Disponibilidad Jugador",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estadoDisponibilidad\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/jugadores/{{jugadorId}}/disponibilidad",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jugadores", "{{jugadorId}}", "disponibilidad"]
            },
            "description": "JugadorController"
          }
        },
        {
          "name": "Responder Invitacion",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"respuesta\": \"ACEPTAR\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/invitaciones/{{invitacionId}}/responder?jugadorId={{jugadorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "invitaciones", "{{invitacionId}}", "responder"],
              "query": [
                { "key": "jugadorId", "value": "{{jugadorId}}" }
              ]
            },
            "description": "InvitacionController"
          }
        },
        {
          "name": "Filtrar Players",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan\",\n  \"position\": \"MIDFIELDER\",\n  \"age\": 21,\n  \"semester\": \"8\",\n  \"available\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/players/filter",
              "host": ["{{baseUrl}}"],
              "path": ["api", "players", "filter"]
            },
            "description": "PlayerController"
          }
        }
      ]
