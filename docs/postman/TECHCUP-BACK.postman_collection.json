    {
      "name": "Lineups",
      "item": [
        {
          "name": "Guardar Alineacion",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Captain-ID", "value": "{{captainId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teamId\": {{teamId}},\n  \"matchId\": {{matchId}},\n  \"formation\": \"F_1_2_3_1\",\n  \"starters\": [\n    { \"playerId\": 11, \"fieldPosition\": \"GOALKEEPER\" },\n    { \"playerId\": 12, \"fieldPosition\": \"DEFENDER\" },\n    { \"playerId\": 13, \"fieldPosition\": \"DEFENDER\" },\n    { \"playerId\": 14, \"fieldPosition\": \"MIDFIELDER\" },\n    { \"playerId\": 15, \"fieldPosition\": \"MIDFIELDER\" },\n    { \"playerId\": 16, \"fieldPosition\": \"MIDFIELDER\" },\n    { \"playerId\": 17, \"fieldPosition\": \"FORWARD\" }\n  ],\n  \"reserveIds\": [18, 19]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/lineups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lineups"]
            },
            "description": "TeamLineupController"
          }
        },
        {
          "name": "Actualizar Alineacion",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Captain-ID", "value": "{{captainId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teamId\": {{teamId}},\n  \"matchId\": {{matchId}},\n  \"formation\": \"F_1_3_2_1\",\n  \"starters\": [\n    { \"playerId\": 11, \"fieldPosition\": \"GOALKEEPER\" },\n    { \"playerId\": 12, \"fieldPosition\": \"DEFENDER\" },\n    { \"playerId\": 13, \"fieldPosition\": \"DEFENDER\" },\n    { \"playerId\": 14, \"fieldPosition\": \"DEFENDER\" },\n    { \"playerId\": 15, \"fieldPosition\": \"MIDFIELDER\" },\n    { \"playerId\": 16, \"fieldPosition\": \"MIDFIELDER\" },\n    { \"playerId\": 17, \"fieldPosition\": \"FORWARD\" }\n  ],\n  \"reserveIds\": [18, 19]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/lineups/{{lineupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lineups", "{{lineupId}}"]
            },
            "description": "TeamLineupController"
          }
        },
        {
          "name": "Obtener Alineacion por Team y Match",
          "request": {
            "method": "GET",
            "header": [
