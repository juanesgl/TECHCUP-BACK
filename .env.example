# Copiar este archivo a ".env" en la raíz del backend y completar los valores.
# El archivo ".env" está en .gitignore y no debe subirse al repositorio.

# --- PostgreSQL (contenedor database) ---
POSTGRES_USER=techcup_user
POSTGRES_PASSWORD=cambiar_password_local
POSTGRES_DB=techcup_db
POSTGRES_PORT=5433

# --- API Spring Boot ---
APP_PORT=8085

# Desarrollo local (IDE o Maven): apunta al Postgres del host (puerto mapeado por compose)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/techcup_db
SPRING_DATASOURCE_USERNAME=techcup_user
SPRING_DATASOURCE_PASSWORD=cambiar_password_local

# JWT (obligatorio; usar un valor largo y aleatorio; no reutilizar en producción sin rotar)
JWT_SECRET=cambiar-por-secreto-largo-minimo-32-caracteres
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
