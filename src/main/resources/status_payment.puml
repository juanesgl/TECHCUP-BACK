@startuml
actor Cliente
participant PaymentController
participant PaymentService

== Happy Path ==
Cliente -> PaymentController : PUT /payments/status
PaymentController -> PaymentService : updateStatus(request)
PaymentService -> PaymentService : valida paymentId y status
PaymentService -> PaymentService : busca pago en lista
PaymentService -> PaymentService : actualiza status
PaymentService --> PaymentController : PaymentResponse OK
PaymentController --> Cliente : 200 - Estado actualizado

== Error - sin paymentId o status ==
Cliente -> PaymentController : PUT /payments/status
PaymentController -> PaymentService : updateStatus(request)
PaymentService -> PaymentService : lanza BusinessException
PaymentService --> PaymentController : GlobalExceptionHandler
PaymentController --> Cliente : 400 - mensaje de error

== Condicional - status PENDING ==
Cliente -> PaymentController : PUT /payments/status {status: PENDING}
PaymentController -> PaymentService : updateStatus(request)
PaymentService -> PaymentService : lanza BusinessException (PENDING no permitido)
PaymentService --> PaymentController : GlobalExceptionHandler
PaymentController --> Cliente : 400 - No se puede asignar PENDING manualmente
@enduml