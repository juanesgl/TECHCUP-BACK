@startuml TC-18 Consulta de Partidos

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequenceParticipant underline

actor "Usuario" as U
participant "PartidoController" as PC
participant "PartidoServiceImpl" as PS
participant "PartidoRepository" as PR
participant "PartidoMapper" as PM

title TC-18: Consulta de Partidos

== Flujo Básico — Consultar con filtros ==

U -> PC: POST /api/partidos/consultar\n{cancha, fecha, equipo, tournamentId}
activate PC

PC -> PS: consultarPartidos(filtro)
activate PS

PS -> PR: findByCancha(cancha) / findByFecha(fecha)\nfindByEquipo(equipo) / findAll()
activate PR
PR --> PS: List<Partido>
deactivate PR

alt Lista vacía
    PS --> PC: throws ResourceNotFoundException\n"No hay partidos programados"
    PC --> U: 404 Not Found
else Lista con resultados
    PS -> PS: ordenar por fecha ascendente
    PS -> PM: toResponseDTOList(partidos)
    activate PM
    PM --> PS: List<PartidoResponseDTO>
    deactivate PM
    PS --> PC: List<PartidoResponseDTO>
    PC --> U: 200 OK\n[lista de partidos]
end

deactivate PS
deactivate PC

== Flujo — Consultar detalle por ID ==

U -> PC: GET /api/partidos/{partidoId}
activate PC

PC -> PS: consultarPartidoPorId(partidoId)
activate PS

PS -> PR: findById(partidoId)
activate PR

alt Partido no encontrado
    PR --> PS: Optional.empty()
    deactivate PR
    PS --> PC: throws ResourceNotFoundException\n"Partido con ID X no encontrado"
    PC --> U: 404 Not Found
else Partido encontrado
    PR --> PS: Optional<Partido>
    PS -> PM: toResponseDTO(partido)
    activate PM
    PM --> PS: PartidoResponseDTO
    deactivate PM
    PS --> PC: PartidoResponseDTO
    PC --> U: 200 OK\n{id, equipoLocal, equipoVisitante,\nfecha, hora, cancha, arbitro, estado}
end

deactivate PS
deactivate PC

== Flujo Alterno TH-01 — Sin resultados ==

U -> PC: POST /api/partidos/consultar\n{cancha: "Cancha Inexistente"}
activate PC
PC -> PS: consultarPartidos(filtro)
activate PS
PS -> PR: findByCancha("Cancha Inexistente")
activate PR
PR --> PS: []
deactivate PR
PS --> PC: throws ResourceNotFoundException
PC --> U: 404 Not Found\n"No hay partidos programados\nque coincidan con los filtros"
deactivate PS
deactivate PC

@enduml